# Supabase PostgreSQL 연결 주소 (예: postgres://postgres.yourproject:password@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres)
DATABASE_URL=your_supabase_postgresql_connection_string

# Gemini API 키 (자연어 리포트 요약 및 대화형 분석용)
GEMINI_API_KEY=your_gemini_api_key

# MQTT 브로커 설정 (실시간 좌석 동기화용)
# 로컬 개발 환경: localhost / 포트 1885
# 배포 환경: HiveMQ Cloud 호스트 주소 / 포트 8883
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1885
MQTT_USERNAME=
MQTT_PASSWORD=

# NicePay 결제 연동 (나이스페이먼츠)
NICEPAY_CLIENT_ID=your_nicepay_client_id
NICEPAY_SECRET_KEY=your_nicepay_secret_key
NICEPAY_API_URL=https://api.nicepay.co.kr/v1
